# =============================================================================
# Bestelsysteem SaaS — Environment Variables
# =============================================================================
# Kopieer dit bestand naar .env.local en vul de waarden in.

# --- Supabase ----------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://jouw-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Data mode ---------------------------------------------------------------
# "supabase" voor productie, leeglaten voor demo-modus (localStorage)
NEXT_PUBLIC_DATA_MODE=supabase

# --- Multi-tenant ------------------------------------------------------------
# UUID van de tenant (restaurant). Wordt per deployment ingesteld.
# Bij eerste setup: maak een tenant aan via /admin en kopieer het UUID.
NEXT_PUBLIC_TENANT_ID=

# --- Admin -------------------------------------------------------------------
# Geheim voor de super-admin API routes (/api/admin/*)
ADMIN_SECRET=wijzig-dit-naar-een-sterk-wachtwoord

# --- Cron (Vercel) -----------------------------------------------------------
# Geheim voor de keep-alive cron job
CRON_SECRET=wijzig-dit-ook
